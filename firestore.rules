rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isPublicProfile(userId) {
      return signedIn()
        && get(/databases/$(database)/documents/publicProfiles/$(userId)).data.profileVisibility == 'public';
    }

    match /users/{userId} {
      allow read: if owns(userId);
      allow create: if owns(userId);
      allow update: if owns(userId)
        && (
          !('lockedStravaAthleteId' in resource.data)
          || !('lockedStravaAthleteId' in request.resource.data)
          || request.resource.data.lockedStravaAthleteId == resource.data.lockedStravaAthleteId
        );

      match /activities/{activityId} {
        allow read: if owns(userId) || isPublicProfile(userId);
        allow write: if owns(userId);
      }

      match /trainingGoalHistory/{historyId} {
        allow read, write: if owns(userId);
      }
    }

    match /feedPosts/{postId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.authorUid == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.authorUid == request.auth.uid;
    }

    match /stravaLinks/{athleteId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.uid == request.auth.uid;
    }

    match /publicProfiles/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if owns(userId);
    }

    match /leaderboardEntries/{userId} {
      allow read: if signedIn();
      allow create, update: if owns(userId)
        && request.resource.data.uid == request.auth.uid;
      allow delete: if owns(userId);
    }

    match /liveSessions/{sessionId} {
      allow read: if signedIn()
        && resource.data.visibility == 'club';
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if signedIn()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.ownerUid == request.auth.uid;
    }
  }
}
